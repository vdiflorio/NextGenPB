+// PB-aligned export sourced from the triangulation grids (see Surface.h).
+// vertex_colors comes from the cavity-filled verticesInsidenessMap; the per-axis
+// CSR edge_crossings come from the bilevel intersection grids + vertList, so the
+// exported crossing positions are byte-identical to the OFF vertices written by
+// triangulate() (with Smooth_Mesh disabled). stag_grid carries the staggered
+// origin (DS->x[0] - hside) so the lattice coincides with the PB/FEM nodes.
+void Surface::exportStagAlignedData(NS::PBAlignedSurfaceData &out,
+                                    const NS::PBAlignedGridDescriptor &stag_grid)
+{
+	const int NX = delphi->nx;
+	const int NY = delphi->ny;
+	const int NZ = delphi->nz;
+
+	// ---- vertex_colors: cavity-filled inside/outside on the staggered lattice ----
+	const int64_t num_vertices = static_cast<int64_t>(NX) * NY * NZ;
+	out.vertex_colors.assign(static_cast<size_t>(num_vertices), 0);
+	for (int k = 0; k < NZ; ++k)
+		for (int j = 0; j < NY; ++j)
+			for (int i = 0; i < NX; ++i)
+				out.vertex_colors[static_cast<size_t>(NS::vertexIndex(i, j, k, stag_grid))] =
+					static_cast<uint8_t>(getStagVertexColor(i, j, k));
+
+	// ---- edge_crossings CSR (one phase-0 crossing per crossed cell-edge) ----
+	const bool have_normals = computeNormals && !normalsList.empty();
+
+#if defined(OPTIMIZE_INTERSECTIONS_MANAGEMENT)
+	// Read the stored 0-based vertList index for the 'dir' edge rooted at cell
+	// (ci,cj,ck); -1 if no ray crossed that edge.
+	auto edge_vidx = [&](unsigned dir, int ci, int cj, int ck) -> int {
+		if (dir == 0)
+			return readBilevelGrid<int>(bilevel_intersectionsMatrixAlongX, -1, ci, cj, ck, NX, NY, NZ);
+		if (dir == 1)
+			return readBilevelGrid<int>(bilevel_intersectionsMatrixAlongY, -1, ci, cj, ck, NX, NY, NZ);
+		return readBilevelGrid<int>(bilevel_intersectionsMatrixAlongZ, -1, ci, cj, ck, NX, NY, NZ);
+	};
+
+	for (unsigned dir = 0; dir < 3; ++dir)
+	{
+		const int64_t ne = NS::edgeCount(dir, stag_grid);
+
+		// the 'dir' edge needs node (.. +1 ..) along dir, so that axis stops one short
+		const int hi0 = (dir == 0) ? NX - 1 : NX;
+		const int hi1 = (dir == 1) ? NY - 1 : NY;
+		const int hi2 = (dir == 2) ? NZ - 1 : NZ;
+
+		std::vector<uint32_t> counts(static_cast<size_t>(ne) + 1, 0);
+		for (int ck = 0; ck < hi2; ++ck)
+			for (int cj = 0; cj < hi1; ++cj)
+				for (int ci = 0; ci < hi0; ++ci)
+				{
+					if (edge_vidx(dir, ci, cj, ck) < 0) continue;
+					const int64_t eid = NS::edgeIndex(dir, ci, cj, ck, stag_grid);
+					if (eid < 0 || eid >= ne) continue;
+					++counts[static_cast<size_t>(eid) + 1];
+				}
+
+		out.edge_offsets[dir].resize(counts.size());
+		uint32_t running = 0;
+		for (size_t i = 0; i < counts.size(); ++i)
+		{
+			running += counts[i];
+			out.edge_offsets[dir][i] = running;
+		}
+		out.edge_crossings[dir].assign(running, NS::PBEdgeCrossing());
+
+		std::vector<uint32_t> positions = out.edge_offsets[dir];
+		for (int ck = 0; ck < hi2; ++ck)
+			for (int cj = 0; cj < hi1; ++cj)
+				for (int ci = 0; ci < hi0; ++ci)
+				{
+					const int vidx = edge_vidx(dir, ci, cj, ck);
+					if (vidx < 0) continue;
+					const int64_t eid = NS::edgeIndex(dir, ci, cj, ck, stag_grid);
+					if (eid < 0 || eid >= ne) continue;
+
+					NS::PBEdgeCrossing crossing;
+					const VERTEX_TYPE *p = &vertList[static_cast<size_t>(vidx) * 3];
+					crossing.point[0] = p[0];
+					crossing.point[1] = p[1];
+					crossing.point[2] = p[2];
+					if (have_normals)
+					{
+						const VERTEX_TYPE *n = &normalsList[static_cast<size_t>(vidx) * 3];
+						crossing.normal[0] = n[0];
+						crossing.normal[1] = n[1];
+						crossing.normal[2] = n[2];
+					}
+					crossing.flags = 0;
+
+					out.edge_crossings[dir][positions[static_cast<size_t>(eid)]++] = crossing;
+				}
+	}
+#else
+	// Without the bilevel intersection grids the per-edge vertex index is not
+	// available; leave empty (well-formed) CSR offsets. This build configuration
+	// is not used by the PB-aligned coupling.
+	for (unsigned dir = 0; dir < 3; ++dir)
+	{
+		out.edge_offsets[dir].assign(static_cast<size_t>(NS::edgeCount(dir, stag_grid)) + 1, 0);
+		out.edge_crossings[dir].clear();
+	}
+#endif
+}
