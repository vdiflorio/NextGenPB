diff --git a/build_no_octave.sh b/build_no_octave.sh
new file mode 100755
index 0000000..b2bc4e0
--- /dev/null
+++ b/build_no_octave.sh
@@ -0,0 +1,42 @@
+#!/bin/sh
+#
+# Build liboctave_file_io WITHOUT Octave (text backend).
+#
+# Compiles the single source octave_file_io.cpp with -DOFIO_NO_OCTAVE so that
+# octave_file_io.h pulls in octave_file_io_shim.h instead of <octave/oct.h>.
+# No autotools / mkoctfile required.
+#
+# Output (install prefix):
+#   octave_file_io/install_no_octave/lib/liboctave_file_io.dylib
+#   octave_file_io/install_no_octave/include/octave_file_io.h
+#   octave_file_io/install_no_octave/include/octave_file_io_shim.h
+#
+set -e
+
+# octave_file_io/  (directory containing this script; may contain '&')
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+SRC="$SCRIPT_DIR/src"
+PREFIX="$SCRIPT_DIR/install_no_octave"
+INCDIR="$PREFIX/include"
+LIBDIR="$PREFIX/lib"
+
+# Use the same compiler as bimpp/NextGenPB for ABI compatibility.
+CXX="${CXX:-mpicxx}"
+LIBNAME="liboctave_file_io.dylib"
+
+mkdir -p "$INCDIR" "$LIBDIR"
+
+echo "Compiling text-backend octave_file_io with '$CXX' ..."
+"$CXX" -std=c++17 -O2 -fPIC -DOFIO_NO_OCTAVE \
+  -I"$SRC" \
+  -dynamiclib -install_name "$LIBDIR/$LIBNAME" \
+  -o "$LIBDIR/$LIBNAME" \
+  "$SRC/octave_file_io.cpp"
+
+cp "$SRC/octave_file_io.h"      "$INCDIR/"
+cp "$SRC/octave_file_io_shim.h" "$INCDIR/"
+
+echo "Installed:"
+echo "  $LIBDIR/$LIBNAME"
+echo "  $INCDIR/octave_file_io.h"
+echo "  $INCDIR/octave_file_io_shim.h"
diff --git a/src/octave_file_io.cpp b/src/octave_file_io.cpp
index c690996..49376e6 100644
--- a/src/octave_file_io.cpp
+++ b/src/octave_file_io.cpp
@@ -11,6 +11,10 @@
 */
 
 #include <iostream>
+#include <fstream>
+
+#ifndef OFIO_NO_OCTAVE
+
 #include <octave/parse.h>
 #include <octave/load-save.h>
 #include <octave/builtin-defun-decls.h>
@@ -196,4 +200,162 @@ octave_clear (void)
   return res;
 }
 
+#else // OFIO_NO_OCTAVE -------------------------------------------------------
+
+//---------------------------------------------------------------------
+//   Text backend (no Octave).
+//
+//   Implements the same API on top of plain std::ofstream/ifstream using the
+//   substitute types from octave_file_io_shim.h. Only the SAVE path is needed
+//   by NextGenPB (and only when map_type=="oct", which is not the default);
+//   it writes a human-readable text dump instead of Octave's binary format.
+//   gzip is ignored (gz_* modes behave like their plain counterparts).
+//   LOAD is unused by NextGenPB and aborts with a clear message rather than
+//   returning silently-empty data.
+//---------------------------------------------------------------------
+
+#include <iomanip>
+#include <cstdlib>
+
+namespace {
+
+  std::string    ofio_filename;
+  octave_io_mode ofio_mode = read_mode;
+
+  bool
+  ofio_fexists (const std::string& fname)
+  {
+    std::ifstream ifile (fname.c_str ());
+    return ifile.good ();
+  }
+
+  void
+  ofio_write_doubles (std::ofstream& ofs, const double* p, std::size_t n)
+  {
+    ofs << std::setprecision (17);
+    for (std::size_t i = 0; i < n; ++i)
+      ofs << p[i] << (((i + 1) % 8 == 0) ? '\n' : ' ');
+    if (n % 8 != 0)
+      ofs << '\n';
+  }
+
+  void
+  ofio_write_idx (std::ofstream& ofs, const octave_idx_type* p, std::size_t n)
+  {
+    for (std::size_t i = 0; i < n; ++i)
+      ofs << static_cast<long long> (p[i]) << (((i + 1) % 8 == 0) ? '\n' : ' ');
+    if (n % 8 != 0)
+      ofs << '\n';
+  }
+
+} // anonymous namespace
+
+int
+octave_io_open (const char* fname, const octave_io_mode mode_in,
+                octave_io_mode* mode_out)
+{
+  *mode_out = mode_in;
+  ofio_mode = mode_in;
+  ofio_filename = fname;
+
+  if (mode_in == write_mode || mode_in == gz_write_mode)
+    {
+      // Truncate / create the file (mirrors Octave creating the file on open).
+      std::ofstream ofs (ofio_filename.c_str (), std::ios::trunc);
+      if (! ofs.good ())
+        return -1;
+      ofs << "# octave_file_io text backend (no Octave)\n";
+      return 0;
+    }
+
+  // read_mode / gz_read_mode: just check the file is there (no gzip check,
+  // the text backend never gzips).
+  return ofio_fexists (fname) ? 0 : -1;
+}
+
+int
+octave_io_close (void)
+{
+  // Nothing to finalize: gzip is intentionally ignored.
+  return 0;
+}
+
+int
+octave_load (const char* /*varname*/, octave_value& /*data*/)
+{
+  std::cerr << "octave_file_io: octave_load is not supported in the no-octave "
+               "text backend (LOAD path is unused by NextGenPB).\n";
+  std::abort ();
+  return -1;
+}
+
+int
+octave_save (const char* varname, const octave_value& data)
+{
+  std::ofstream ofs (ofio_filename.c_str (), std::ios::app);
+  if (! ofs.good ())
+    return -1;
+
+  ofs << "VAR " << varname << '\n';
+
+  if (data.kind_ == octave_value::K_MAP && data.map_)
+    {
+      const std::map<std::string, octave_value>& fields = data.map_->fields_;
+      ofs << "MAP " << fields.size () << '\n';
+
+      for (std::map<std::string, octave_value>::const_iterator it
+             = fields.begin (); it != fields.end (); ++it)
+        {
+          const std::string&  name = it->first;
+          const octave_value& v    = it->second;
+
+          switch (v.kind_)
+            {
+            case octave_value::K_MATRIX:
+              ofs << "FIELD " << name << " matrix "
+                  << v.mat_.rows_ << ' ' << v.mat_.cols_ << '\n';
+              ofio_write_doubles (ofs, v.mat_.data_.data (),
+                                  v.mat_.data_.size ());
+              break;
+
+            case octave_value::K_COLUMN:
+              ofs << "FIELD " << name << " column "
+                  << v.col_.data_.size () << " 1\n";
+              ofio_write_doubles (ofs, v.col_.data_.data (),
+                                  v.col_.data_.size ());
+              break;
+
+            case octave_value::K_ARRAY_IDX:
+              ofs << "FIELD " << name << " array_idx "
+                  << v.arr_.rows_ << ' ' << v.arr_.cols_ << '\n';
+              ofio_write_idx (ofs, v.arr_.data_.data (),
+                              v.arr_.data_.size ());
+              break;
+
+            default:
+              ofs << "FIELD " << name << " empty 0 0\n";
+              break;
+            }
+        }
+
+      ofs << "ENDMAP\n";
+    }
+  else
+    {
+      // libbim only ever saves a scalar map; record anything else explicitly
+      // instead of writing wrong/empty data silently.
+      ofs << "UNSUPPORTED_VALUE\n";
+    }
+
+  return 0;
+}
+
+int
+octave_clear (void)
+{
+  return 0;
+}
+
+#endif // OFIO_NO_OCTAVE
+
 
