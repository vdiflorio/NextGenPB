diff --git a/src/octave_file_io_shim.h b/src/octave_file_io_shim.h
new file mode 100644
index 0000000..ff47d9d
--- /dev/null
+++ b/src/octave_file_io_shim.h
@@ -0,0 +1,183 @@
+/*
+  octave_file_io_shim.h
+
+  Substitute (shim) types used to build octave_file_io / bimpp WITHOUT a real
+  Octave installation. Activated by defining the macro OFIO_NO_OCTAVE at build
+  time (see octave_file_io.h).
+
+  Scope: this header only defines the *minimal* subset of the Octave API that
+  libbim (bimpp/src/tmesh.cpp and tmesh_3d.cpp) actually uses. It is NOT a
+  general Octave replacement. The bimpp tests/examples use a richer API and
+  are not built in the no-octave configuration.
+
+  Members actually used by libbim:
+    octave_idx_type                       integer index type
+    dim_vector(r, c)                      2-D shape
+    Matrix(r, c, fill), fortran_vec(), cols()
+    ColumnVector(n, fill), fortran_vec()
+    Array<octave_idx_type>(dim_vector, fill), copy, fortran_vec(), cols(), numel()
+    octave_scalar_map: assign(name, value), contents(name), scalar_map_value()
+    octave_value: ctor from {default, map, Matrix, ColumnVector, Array<idx>},
+                  matrix_value(), octave_idx_type_vector_value(b,b,b),
+                  scalar_map_value()
+
+  Matrix/ColumnVector/Array store their data column-major in a contiguous
+  std::vector; fortran_vec() returns the raw pointer, matching Octave.
+*/
+
+#ifndef OCTAVE_FILE_IO_SHIM_H
+#define OCTAVE_FILE_IO_SHIM_H
+
+#include <cstdint>
+#include <cstddef>
+#include <vector>
+#include <string>
+#include <map>
+#include <memory>
+
+typedef int64_t octave_idx_type;
+
+//---------------------------------------------------------------------
+//  Shape descriptor
+//---------------------------------------------------------------------
+struct dim_vector
+{
+  octave_idx_type rows_;
+  octave_idx_type cols_;
+
+  dim_vector (octave_idx_type r, octave_idx_type c) : rows_ (r), cols_ (c) {}
+};
+
+//---------------------------------------------------------------------
+//  Dense column vector of doubles
+//---------------------------------------------------------------------
+class ColumnVector
+{
+public:
+  std::vector<double> data_;
+
+  ColumnVector () {}
+  ColumnVector (octave_idx_type n, double fill = 0.0)
+    : data_ (static_cast<std::size_t> (n < 0 ? 0 : n), fill) {}
+
+  double*       fortran_vec ()       { return data_.data (); }
+  const double* fortran_vec () const { return data_.data (); }
+
+  octave_idx_type numel () const
+  { return static_cast<octave_idx_type> (data_.size ()); }
+};
+
+//---------------------------------------------------------------------
+//  Dense (rows x cols) matrix of doubles, column-major
+//---------------------------------------------------------------------
+class Matrix
+{
+public:
+  octave_idx_type    rows_;
+  octave_idx_type    cols_;
+  std::vector<double> data_;
+
+  Matrix () : rows_ (0), cols_ (0) {}
+  Matrix (octave_idx_type r, octave_idx_type c, double fill = 0.0)
+    : rows_ (r), cols_ (c),
+      data_ (static_cast<std::size_t> ((r < 0 ? 0 : r) * (c < 0 ? 0 : c)), fill) {}
+
+  double*       fortran_vec ()       { return data_.data (); }
+  const double* fortran_vec () const { return data_.data (); }
+
+  octave_idx_type rows  () const { return rows_; }
+  octave_idx_type cols  () const { return cols_; }
+  octave_idx_type numel () const
+  { return static_cast<octave_idx_type> (data_.size ()); }
+};
+
+//---------------------------------------------------------------------
+//  Dense (rows x cols) array of T, column-major
+//---------------------------------------------------------------------
+template <class T>
+class Array
+{
+public:
+  octave_idx_type rows_;
+  octave_idx_type cols_;
+  std::vector<T>  data_;
+
+  Array () : rows_ (0), cols_ (0) {}
+  Array (const dim_vector& dv, T fill)
+    : rows_ (dv.rows_), cols_ (dv.cols_),
+      data_ (static_cast<std::size_t> ((dv.rows_ < 0 ? 0 : dv.rows_)
+                                       * (dv.cols_ < 0 ? 0 : dv.cols_)), fill) {}
+
+  T*       fortran_vec ()       { return data_.data (); }
+  const T* fortran_vec () const { return data_.data (); }
+
+  octave_idx_type rows  () const { return rows_; }
+  octave_idx_type cols  () const { return cols_; }
+  octave_idx_type numel () const
+  { return static_cast<octave_idx_type> (data_.size ()); }
+};
+
+//---------------------------------------------------------------------
+//  Tagged value: empty | scalar_map | Matrix | ColumnVector | Array<idx>
+//---------------------------------------------------------------------
+class octave_scalar_map;   // forward (mutually recursive with octave_value)
+
+class octave_value
+{
+public:
+  enum kind_t { K_EMPTY, K_MAP, K_MATRIX, K_COLUMN, K_ARRAY_IDX };
+
+  kind_t                  kind_ = K_EMPTY;
+  Matrix                  mat_;
+  ColumnVector            col_;
+  Array<octave_idx_type>  arr_;
+  std::shared_ptr<octave_scalar_map> map_;
+
+  octave_value () : kind_ (K_EMPTY) {}
+
+  // Non-explicit on purpose: libbim relies on implicit conversion in
+  // the_map.assign("p", oct_p) and octave_value (the_map).
+  octave_value (const Matrix& m)                 : kind_ (K_MATRIX),    mat_ (m) {}
+  octave_value (const ColumnVector& c)           : kind_ (K_COLUMN),    col_ (c) {}
+  octave_value (const Array<octave_idx_type>& a) : kind_ (K_ARRAY_IDX), arr_ (a) {}
+  octave_value (const octave_scalar_map& m);     // out-of-line (see below)
+
+  Matrix matrix_value () const { return mat_; }
+
+  // The three bool flags select Octave conversion behaviour; here we always
+  // return the stored index array unchanged (we control the format).
+  Array<octave_idx_type>
+  octave_idx_type_vector_value (bool = false, bool = false, bool = false) const
+  { return arr_; }
+
+  octave_scalar_map scalar_map_value () const;   // out-of-line (see below)
+};
+
+//---------------------------------------------------------------------
+//  Struct (named fields -> octave_value)
+//---------------------------------------------------------------------
+class octave_scalar_map
+{
+public:
+  std::map<std::string, octave_value> fields_;
+
+  void assign (const std::string& name, const octave_value& val)
+  { fields_[name] = val; }
+
+  octave_value contents (const std::string& name) const
+  {
+    std::map<std::string, octave_value>::const_iterator it = fields_.find (name);
+    return (it == fields_.end ()) ? octave_value () : it->second;
+  }
+};
+
+//---------------------------------------------------------------------
+//  Out-of-line members of octave_value that need octave_scalar_map complete
+//---------------------------------------------------------------------
+inline octave_value::octave_value (const octave_scalar_map& m)
+  : kind_ (K_MAP), map_ (std::make_shared<octave_scalar_map> (m)) {}
+
+inline octave_scalar_map octave_value::scalar_map_value () const
+{ return map_ ? *map_ : octave_scalar_map (); }
+
+#endif // OCTAVE_FILE_IO_SHIM_H
